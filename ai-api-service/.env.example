PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Qwen-first small-model defaults for Codespaces-friendly development.
QWEN_MODEL=Qwen2.5-1.5B-Instruct

# When not provided, the service falls back to local rule-based analysis.
QWEN_BASE_URL=
QWEN_API_KEY=

# Optional OpenAI-compatible chat completions path.
QWEN_CHAT_PATH=/chat/completions
