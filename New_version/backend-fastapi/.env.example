APP_NAME="桑榆智盾后端服务"
APP_ENV="development"
APP_HOST="0.0.0.0"
APP_PORT="8000"
APP_DEBUG="true"
APP_API_PREFIX="/api/v1"
APP_ALLOWED_ORIGINS='["http://localhost:5666","http://localhost:4173","http://localhost:3000"]'
APP_JWT_SECRET="change-this-secret-at-least-32-chars"
APP_JWT_ALGORITHM="HS256"
APP_ACCESS_TOKEN_EXPIRE_MINUTES="120"
APP_LOG_LEVEL="INFO"
APP_DATABASE_URL="postgresql+psycopg://postgres:postgres@127.0.0.1:5432/guard_silver"
CHAT_MESSAGE_RATE_LIMIT_COUNT="20"
CHAT_MESSAGE_RATE_LIMIT_WINDOW_SECONDS="60"
CHAT_AUDIT_ENABLED="true"
CALL_STUN_SERVERS='["stun:stun.l.google.com:19302"]'
CALL_TURN_URL=""
CALL_TURN_USERNAME=""
CALL_TURN_PASSWORD=""
AUDIO_GUARD_ENABLED="true"
AUDIO_GUARD_SCRIPT_PATH="../read_audio_guard_improved.sh"
AUDIO_GUARD_TIMEOUT_SECONDS="180"
